<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background" />
        </shape>
    </item>
    <item android:gravity="top|end" android:top="-40dp" android:right="-60dp">
        <shape android:shape="oval">
            <size android:width="220dp" android:height="220dp" />
            <solid android:color="#33C084FC" />
        </shape>
    </item>
    <item android:gravity="bottom|start" android:left="-40dp" android:bottom="-40dp">
        <shape android:shape="oval">
            <size android:width="180dp" android:height="180dp" />
            <solid android:color="#40E9D5FF" />
        </shape>
    </item>
</layer-list>
