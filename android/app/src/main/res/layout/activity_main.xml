<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@color/nav_bar_background"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivNavHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/primary" />

            <TextView
                android:id="@+id/tvNavHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/nav_home"
                android:textColor="@color/primary"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAdoption"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivNavAdoption"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_paw"
                app:tint="@color/nav_bar_unselected" />

            <TextView
                android:id="@+id/tvNavAdoption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/nav_pet_adoption"
                android:textColor="@color/nav_bar_unselected"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPetFinder"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivNavPetFinder"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_missing"
                app:tint="@color/nav_bar_unselected" />

            <TextView
                android:id="@+id/tvNavPetFinder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/nav_pet_finder"
                android:textColor="@color/nav_bar_unselected"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navApplications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivNavApplications"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_file_text"
                app:tint="@color/nav_bar_unselected" />

            <TextView
                android:id="@+id/tvNavApplications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/nav_applications"
                android:textColor="@color/nav_bar_unselected"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivNavProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/nav_bar_unselected" />

            <TextView
                android:id="@+id/tvNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/nav_profile"
                android:textColor="@color/nav_bar_unselected"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
